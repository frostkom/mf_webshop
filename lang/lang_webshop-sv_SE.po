msgstr "Steg 3: Hämta API-nycklar"

#: ../include/classes.php:3757
msgid "Navigate to 'Developers' in the sidebar."
msgstr "Gå till 'Developers' i sidomenyn."

#: ../include/classes.php:3758
msgid "Click on 'API keys' under the 'Developers' tab."
msgstr "Klicka på 'API keys' under fliken 'Developers'."

#: ../include/classes.php:3759
msgid "You will see both the Publishable key and the Secret key there."
msgstr "Du kommer att se både den publika nyckeln (Publishable key) och den hemliga nyckeln (Secret key) där."

#: ../include/classes.php:3760
msgid "Click the eye icon next to the key name to reveal the Secret key if it is hidden."
msgstr "Klicka på ögonikonen bredvid nyckelns namn för att visa den hemliga nyckeln om den är dolt."

